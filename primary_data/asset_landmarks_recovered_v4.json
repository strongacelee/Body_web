    else:
        landmarks_db = {}
        
    # sample_model.png의 정밀 랜드마크 딕셔너리 확보
    sample_model_lms = landmarks_db.get("sample_model.png", {})
    if not sample_model_lms:
        print("Error: 데이터베이스 내에 sample_model.png 랜드마크 정보가 존재하지 않습니다.")
        return
        
    # sample_model의 눈, 코 3개 
<truncated 2830 bytes>
된 에셋 저장
        dest_path = os.path.join(dest_dir, dest_name)
        cv2.imwrite(dest_path, rgba)
        print(f"에셋 저장 완료: {dest_path}")
        
        # 3. 아핀 역투영 변환(Affine Back-projection)을 통한 33개 랜드마크 복원
        # 에셋 가로폭 w를 기준 척도로 삼고 262px 기준의 최적 얼굴 템플릿 비례를 스케일링하여 왜곡 방지
        scale_factor = w / 262.0
        x_center = w / 2.0
        
        asset_pts = np.float32([
            [x_center, 215.0 * scale_factor],                               # 코 (0)
            [x_center + 38.0 * scale_factor, 172.0 * scale_factor],        # 왼눈 (2)
            [x_center - 38.0 * scale_factor, 172.0 * scale_factor]         # 오른눈 (5)
        ])
        
        # sample_model ➡️ 에셋 캔버스로의 변환 행렬 M 구함
        M = cv2.getAffineTransform(sample_pts, asset_pts)
        
        # 모든 33개 랜드마크에 대해 공간 투영하여 픽셀 좌표 역산
        transformed_lms = {}
        for pt_id, pt_coords in sample_model_lms.items():
            u, v, z = pt_coords
            # 아핀 투영 연산 적용
            xy = M @ np.float32([u, v, 1.0])
            x_final = float(xy[0])
            y_final = float(xy[1])
            transformed_lms[int(pt_id)] = [x_final, y_final, z]
            
        # 데이터베이스에 기입
        landmarks_db[dest_name] = transformed_lms
        print(f"랜드마크 복원 완료: {dest_name} (33개 점)")
        
    # 데이터베이스 저장
    with open(db_path, "w", encoding="utf-8") as f:
        json.dump(landmarks_db, f, indent=4)
    print(f"데이터베이스 업데이트 성공: {db_path}")

